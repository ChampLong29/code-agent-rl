# =============================================================================
#  Agentic RL Training — 环境变量配置
#  复制本文件为 .env 并按需填写
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic API（teacher rollout / SFT 数据生成）
# -----------------------------------------------------------------------------

# 直连 Anthropic（需要国际网络）
# ANTHROPIC_API_KEY=sk-ant-xxx

# 通过中转代理（国内推荐）
# ANTHROPIC_BASE_URL=https://your-proxy.com
# ANTHROPIC_API_KEY=sk-xxx

# 用于 teacher rollout 的模型（便宜、快速即可）
# TEACHER_MODEL=claude-3-5-haiku-20241022

# -----------------------------------------------------------------------------
# HuggingFace（模型下载）
# -----------------------------------------------------------------------------

# HF_TOKEN=hf_xxx

# 国内镜像加速（强烈推荐）
# HF_ENDPOINT=https://hf-mirror.com

# -----------------------------------------------------------------------------
# 训练监控（可选，至少配置其中一个）
# -----------------------------------------------------------------------------

# WandB（国际）
# WANDB_API_KEY=xxx
# WANDB_PROJECT=code-agent-rl
# WANDB_ENTITY=your-username

# SwanLab（国内友好，推荐）
# SWANLAB_API_KEY=xxx
# SWANLAB_PROJECT=code-agent-rl
# SWANLAB_WORKSPACE=your-username

# 同时启用两者：MONITOR_BACKEND=wandb,swanlab
MONITOR_BACKEND=wandb

# -----------------------------------------------------------------------------
# 训练参数覆盖（可选，优先级高于 configs/*.yaml）
# -----------------------------------------------------------------------------

# BASE_MODEL=Qwen/Qwen2.5-Coder-1.5B-Instruct
# USE_4BIT=0          # 设为 1 启用 QLoRA
# GRPO_GROUP_SIZE=8
# MAX_STEPS=10
